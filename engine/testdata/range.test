  load 60s
  http_requests_total{pod="nginx-1", series="1"} 1+1x40
eval range from 0 to 30m step 30s http_requests_total * (sum_over_time(http_requests_total[5m:1m]) > 0)

clear

# sum_over_time subquery with outer step larger than inner step
  load 60s
  http_requests_total{pod="nginx-1", series="1"} 1+1x40
eval range from 0 to 30m step 30s sum_over_time(sum_over_time(http_requests_total[2m])[5m:1m])

clear

# sum_over_time subquery with outer step equal to inner step
  load 60s
  http_requests_total{pod="nginx-1", series="1"} 1+1x40
eval range from 0 to 30m step 30s sum_over_time(sum_over_time(http_requests_total[2m])[5m:30s])

clear

# sum_over_time subquery with outer step smaller than inner step
  load 60s
  http_requests_total{pod="nginx-1", series="1"} 1+1x40
eval range from 0 to 30m step 30s sum_over_time(sum_over_time(http_requests_total[2m])[5m:15s])

clear

# sum_over_time subquery with aggregation
  load 10s
  http_requests_total{pod="nginx-1", series="1"} 1+1x40
  http_requests_total{pod="nginx-2", series="2"} 2+2x50
eval range from 0 to 30m step 30s sum_over_time(sum by (pod) (http_requests_total)[5m:1m])

clear

# rate subquery with outer @ modifier
  load 30s
  http_requests_total{pod="nginx-1", series="1"} 1+1x40
  http_requests_total{pod="nginx-2", series="2"} 2+2x50
eval range from 0 to 30m step 30s rate(http_requests_total[20s:10s] @ 100.000)

clear

# rate subquery with offset
  load 10s
  http_requests_total{pod="nginx-1", series="1"} 1+2x40
eval range from 0 to 30m step 30s rate(http_requests_total[20s:10s] offset 20s)

clear

