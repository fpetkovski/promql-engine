# fuzz parser crash
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 46.00+13.00x40
  http_requests_total{pod="nginx-2", route="/"}  2+5.25x40
eval range from 0 to 30m step 30s avg(
    {__name__="http_requests_total",route!="/"} offset -4m43s
  ^
    {__name__="http_requests_total",route!="/"}
)

clear

# fuzz
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 46.00+13.00x40
  http_requests_total{pod="nginx-2", route="/"}  2+5.25x40
eval range from 0 to 30m step 30s sum(quantile by (route) (-0.5044968945760265, {__name__="http_requests_total",route="/"}))

clear

# fuzz -0
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 46.00+1.00x40
  http_requests_total{pod="nginx-2", route="/"} -6+4.20x40
eval range from 0 to 30m step 30s count_values without (pod, route) ("value", -1 * http_requests_total * 0)

clear

# predict_linear fuzz
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 48.00+9.17x40
  http_requests_total{pod="nginx-2", route="/"} -108+173.00x40
eval range from 0 to 30m step 30s predict_linear(http_requests_total{route="/"}[1h:1m] offset 1m, 60)

clear

# duplicate label fuzz
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 41.00+0.20x40
  http_requests_total{pod="nginx-2", route="/"} 51+21.71x40
eval range from 0 to 30m step 30s -avg by (__name__) (
  (-group({__name__="http_requests_total"} @ 54.013) or {__name__="http_requests_total"} offset 1m32s)
)

clear

# timestamp fuzz 1
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 0.20+9.00x40
  http_requests_total{pod="nginx-2", route="/"}  6+60.00x40
eval range from 0 to 30m step 30s timestamp(last_over_time(http_requests_total{route="/"}[1h]))

clear

# timestamp fuzz 2
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 8.00+9.17x40
  http_requests_total{pod="nginx-2", route="/"} -12+103.00x40
eval range from 0 to 30m step 30s timestamp(
  http_requests_total{pod="nginx-1"} >= bool (http_requests_total < 2 * http_requests_total)
)

clear

# timestamp with multiple parenthesis
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 8.00+9.17x40
  http_requests_total{pod="nginx-2", route="/"} -12+103.00x40
eval range from 0 to 30m step 30s timestamp((http_requests_total))

clear

# subqueries in binary expression
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 1.00+0.20x40
  http_requests_total{pod="nginx-2", route="/"} -44+2.00x40
eval range from 0 to 30m step 30s absent_over_time(http_requests_total @ end()[1h:1m])
or
  avg_over_time(http_requests_total @ end()[1h:1m])

clear

# nested unary negation
eval range from 0 to 30m step 30s 1 / (-(2 * 2))

# stddev with large values
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 1e+181
  http_requests_total{pod="nginx-2", route="/"} 1e+80
eval range from 0 to 30m step 30s stddev(http_requests_total)

clear

