# eval instant at 2m ts_of_min_over_time, with 2m lookback
  load 5s
  http_requests{path="/foo"}	0+10x10
  http_requests{path="/bar"}	0+10x5 0+10x4
eval instant at 120s ts_of_min_over_time(http_requests[2m])

clear

# eval instant at 2m ts_of_max_over_time, with 2m lookback
  load 5s
  http_requests{path="/foo"}	0+10x10
  http_requests{path="/bar"}	0+10x5 0+10x4
eval instant at 120s ts_of_max_over_time(http_requests[2m])

clear

# eval instant at 2m ts_of_max_over_time, with subquery
  load 5s
  http_requests{path="/foo"}	0+10x10
  http_requests{path="/bar"}	0+10x5 0+10x4
eval instant at 120s ts_of_max_over_time(rate(http_requests[30s])[2m:5s])

clear

# count_values fuzz
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 51.00+1.00x40
  http_requests_total{pod="nginx-2", route="/"} -74+14.00x40
eval instant at 50s count_values without () (
  "value",
    (atanh(http_requests_total{pod="nginx-1"}) > tanh(http_requests_total{route="/"}))
  or
    avg by (pod, __name__) (http_requests_total{route="/"})
)

clear

# sum evaluates to -0 fuzz
  load 30s
  http_requests_total{pod="nginx-2", route="/"}  0
eval instant at 0s sum by (pod) (-http_requests_total) atan2 -0

clear

# count_values
  load 30s
  version{foo="bar"} 1
  version{foo="baz"} 1
  version{foo="quz"} 2
eval instant at 0s count_values("val", version)

clear

# binary pairing early exit fuzz
  load 30s
  http_requests_total{pod="nginx-1", route="/"} 33.00+1.00x40
  http_requests_total{pod="nginx-2", route="/"}  1+2.00x40
eval instant at 0s avg without (route) (avg(http_requests_total) / http_requests_total)
<=
  sum by (__name__) (http_requests_total or avg(http_requests_total))

clear

# offset and @ modifiers
  load 30s
  http_requests_total{pod="nginx-0", route="/"} 1+1x30
eval instant at 300s http_requests_total @ end() offset 2m

clear

# timestamp - offset modifier
  load 30s
  http_requests_total{pod="nginx-0", route="/"} 0x30
eval instant at 300s timestamp(http_requests_total offset 2m)

clear

# timestamp - @ modifier
  load 30s
  http_requests_total{pod="nginx-0", route="/"} 0x30
eval instant at 300s timestamp(http_requests_total @ 60.000)

clear

# timestamp - nested functions with offset
  load 30s
  http_requests_total{pod="nginx-0", route="/"} 0x30
eval instant at 300s timestamp(timestamp(http_requests_total offset 2m))

clear

